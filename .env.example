# Server-only OpenAI credential. Never prefix with NEXT_PUBLIC_ or commit a value.
OPENAI_API_KEY=

# Founder-approved initial public usage controls.
AI_MAX_MESSAGES_PER_SESSION=5
AI_MAX_MESSAGES_PER_IP_PER_DAY=10
AI_MAX_INPUT_CHARACTERS=1500
AI_MAX_OUTPUT_TOKENS=700
AI_REQUEST_COOLDOWN_SECONDS=5
AI_REQUEST_TIMEOUT_SECONDS=30

# Feature flags.
AI_PUBLIC_CHAT_ENABLED=true
AI_BUSINESS_ASSESSMENT_ENABLED=true
AI_WEBSITE_ASSESSMENT_ENABLED=true
AI_ESTIMATOR_ENABLED=true
AI_LIVE_RESEARCH_ENABLED=false
AI_VOICE_ENABLED=false
AI_ANIMATED_AVATAR_ENABLED=false

# Local automated/demo lead workflow only. Never enable in production.
AI_LEAD_TEST_MODE=false
